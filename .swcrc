{
	"$schema": "https://swc.rs/schema.json",
	"jsc": {
		"parser": {
			"syntax": "typescript",
			"jsx": false,
			"dynamicImport": false,
			"privateMethod": false,
			"functionBind": false,
			"exportDefaultFrom": false,
			"exportNamespaceFrom": false,
			"decorators": false,
			"decoratorsBeforeExport": false,
			"topLevelAwait": false,
			"importMeta": false
		},
		"baseUrl": ".",
		"target": "esnext",
		"loose": false,
		"externalHelpers": false,
		"keepClassNames": false,
		"experimental": {
			"keepImportAttributes": true
		}
	},
	"minify": true,
	"isModule": "unknown",
	"module": {
		"type": "nodenext",
		"resolveFully": true
	}
}

{
  "name": "fivecms",
  "version": "26.2.1",
  "description": "A flat-file CMS designed to be as flexible as possible.",
  "homepage": "https://github.com/BriceC74/fivecms#readme",
  "bugs": {
    "url": "https://github.com/BriceC74/fivecms/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BriceC74/fivecms.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "npm run type-check && swc src -d dist --strip-leading-paths",
    "start": "node dist/index.js",
    "dev": "node src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apollo/server": "*",
    "graphql": "*"
  },
  "devDependencies": {
    "@swc/cli": "*",
    "@swc/core": "*",
    "@types/node": "*",
    "typescript": "*"
  }
}